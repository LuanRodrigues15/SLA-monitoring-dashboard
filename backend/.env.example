# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# Trino
TRINO_HOST=trino.example.internal
TRINO_PORT=8081
TRINO_USER=admin
TRINO_CATALOG=iceberg
TRINO_SCHEMA_OPS=silver_ops
TRINO_SCHEMA_BRONZE=bronze_legacy
TRINO_SCHEMA_ZABBIX=bronze_monitoring
TRINO_SCHEMA_GOLD_ZABBIX=gold_monitoring
TRINO_SCHEMA_TICKETING=bronze_ticketing
TRINO_SCHEMA_BILLING=bronze_billing

# Nome da tabela de tickets (configurável caso o ambiente mude)
TICKETING_TABLE=ticketing_ops

# SFTP
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=sftp-user
SFTP_PASS=change-me
SFTP_REMOTE_PATH=/upload

# Helpdesk / ITSM API
HELPDESK_API_BASE=https://helpdesk.example.com
HELPDESK_BEARER_TOKEN=

# CORS
CORS_ORIGINS=["http://localhost:5173"]
